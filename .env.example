# =========================================================
# Agent OS — Environment Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to Git.
# =========================================================

# App
NODE_ENV=development
APP_NAME=Agent OS
PORT=3000
LLM_ROUTER_URL=http://llm-router:4000

# Tenant / Org
ORG_ID=org_demo_001
ORG_NAME=Demo Org

# Authentication
# Use Clerk (free up to 10K MAUs) or LogTo self-hosted
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
JWT_SECRET=change-me-to-a-random-32-char-string

# Database
# Neon free Postgres: https://neon.tech
DATABASE_URL=postgresql://user:pass@neon-host/agentos?sslmode=require
# OR self-hosted Postgres
# DATABASE_URL=postgresql://agentos:password@postgres:5432/agentos

# Redis (self-hosted)
REDIS_URL=redis://redis:6379

# Neo4j (self-hosted)
NEO4J_URL=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-strong-password

# Knowledge Graph / Vector Memory
VECTOR_DIMENSION=1536

# Free LLM Provider Keys
# Get keys from:
# - Gemini: https://aistudio.google.com/app/apikey
# - Groq: https://console.groq.com
# - Cerebras: https://cloud.cerebras.ai
# - OpenRouter: https://openrouter.ai
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk_...
OPENROUTER_API_KEY=sk-or-v1-...

# Local LLM (Ollama)
OLLAMA_URL=http://ollama:11434

# GitHub (optional; used by Engineering Agent)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo

# Secrets (Infisical or file-based)
INFISICAL_ENABLED=false
INFISICAL_SITE_URL=http://localhost:8080
INFISICAL_TOKEN=

# Cloudflare (for R2 backups and Pages)
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_R2_ACCESS_KEY_ID=...
CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
CLOUDFLARE_R2_BUCKET=agent-os-backups
CLOUDFLARE_R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# Monitoring
GRAFANA_CLOUD_URL=https://<instance>.grafana.net
GRAFANA_CLOUD_API_KEY=...

# Tailscale (optional admin VPN)
TAILSCALE_ENABLED=false
TAILSCALE_AUTH_KEY=tskey-auth-...
